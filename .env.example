# Copy this to .env and fill in your values
# MathTutor — Environment Configuration

# Security
SECRET_KEY=change-this-to-a-random-64-char-hex-string

# LLM Provider (openai | anthropic | gemini | custom)
LLM_PROVIDER=openai
LLM_API_KEY=sk-...
LLM_MODEL_NAME=gpt-4o
LLM_BASE_URL=

# OCR Mode (local | vision_api | hybrid)
# local = Tesseract only, vision_api = LLM vision, hybrid = local first then vision
OCR_MODE=hybrid

# Network
LAN_ONLY_MODE=1

# App
APP_VERSION=1.0.0
DEBUG=0
